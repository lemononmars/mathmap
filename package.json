		"@types/katex": "^0.16.8",
		"@types/node": "^25.9.2",
		"jsdom": "^29.1.1",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@lucide/svelte": "^1.17.0",
		"@supabase/supabase-js": "^2.108.1",
